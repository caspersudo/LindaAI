# Copy to .env for local dev. All three Supabase values are in your project's
# Settings → API page.
ALLOWED_ORIGINS=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
OPENAI_API_KEY=sk-...

# M-Pesa Daraja (leave blank to disable paywall during development)
# Get credentials at https://developer.safaricom.co.ke
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=
DARAJA_BASE=https://sandbox.safaricom.co.ke
API_BASE_URL=https://lindaai-api.onrender.com
REPORT_PRICE_KES=500
